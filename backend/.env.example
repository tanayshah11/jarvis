# Use this for Docker-based PostgreSQL with AGE:
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis_secret@localhost:5432/jarvis

# Or use this for local PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jarvis
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ENCRYPTION_KEY=your-32-byte-encryption-key-here
ENVIRONMENT=development

# AI Provider API Keys — replace each placeholder with your own key.
# Anthropic:  https://console.anthropic.com/settings/keys
# OpenAI:     https://platform.openai.com/api-keys
# Llama:      https://llama.developer.meta.com
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
OPENAI_API_KEY=sk-REPLACE_ME

# AI Model Settings (optional)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-5-nano-2025-08-07
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Llama API (Meta) - Free tier available at https://llama.developer.meta.com
LLAMA_API_KEY="LLM|REPLACE_ME"
LLAMA_MODEL=Llama-4-Maverick-17B-128E-Instruct-FP8
